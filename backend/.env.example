# Server
PORT=4000
NODE_ENV=development

# PostgreSQL — leads storage
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=vitto
POSTGRES_USER=postgres
POSTGRES_PASSWORD=yourpassword
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/vitto

# MongoDB — OTP session storage (TTL index)
MONGODB_URI=mongodb://localhost:27017/vitto

# JWT
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=24h

# CORS — set to your frontend URL
CORS_ORIGIN=http://localhost:3000

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
OTP_RATE_LIMIT_MAX=5
