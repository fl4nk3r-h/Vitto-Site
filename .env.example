# Environment Configuration for Vitto

# Next.js
NEXT_PUBLIC_API_URL=http://localhost:3000

# Database (PostgreSQL - for production)
# DATABASE_URL=postgresql://user:password@localhost:5432/vitto_db

# Cache & Sessions (Redis - for production)
# REDIS_URL=redis://localhost:6379

# Email Service (SendGrid or AWS SES - for production)
# SENDGRID_API_KEY=your_sendgrid_key
# SENDGRID_FROM_EMAIL=noreply@vitto.ai
# AWS_SES_REGION=us-east-1
# AWS_SES_ACCESS_KEY_ID=your_access_key
# AWS_SES_SECRET_ACCESS_KEY=your_secret_key

# Node Environment
NODE_ENV=development

# Debug Mode (shows OTP in response during development)
DEBUG=true
